# Copy this file to `.env` and fill in your local values.

MONGODB_URI=mongodb+srv://username:password@clustername.mongodb.net/smartcampus?appName=SmartCampus

# Backend defaults
SERVER_PORT=8080

# Google OAuth2 placeholders for Member 4
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
